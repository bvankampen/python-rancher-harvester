apiVersion: k8s.cni.cncf.io/v1
kind: NetworkAttachmentDefinition
metadata:
  annotations:
    network.harvesterhci.io/route: '{"mode":"manual","cidr":"{{ cidr }}","gateway":"{{ blueprint.network.gateway }}","connectivity":"true"}'
  labels:
    network.harvesterhci.io/clusternetwork: {{ blueprint.network.clusternetwork }}
    network.harvesterhci.io/ready: "true"
    network.harvesterhci.io/type: L2VlanNetwork
    network.harvesterhci.io/vlan-id: "{{ blueprint.network.vlan_id }}"
  name: {{ name }}
  namespace: {{ namespace }}
spec:
  config: '{"cniVersion":"0.3.1","name":"{{ name }}","type":"bridge","bridge":"{{ blueprint.network.bridge_interface }}","promiscMode":true,"vlan": {{ blueprint.network.vlan_id }},"ipam":{}}'
